@model IEnumerable<BlackBelt.Controllers.ControleMensalidadeViewModel>

@{
    ViewData["Title"] = "Controle de Mensalidades";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Mensalidades.css" asp-append-version="true" />
}

<h1 class="text-center m-5">Controle de Mensalidades</h1>

<div class="container text-center">
    <div class="mb-5">
        <a class="btn btn-dark" style="border-radius: 20px; width:180px" asp-area="" asp-controller="Home" asp-action="Index">Voltar</a>
    </div>

    <!-- Filtros -->
    <form method="get" asp-controller="Mensalidades" asp-action="Index" class="row filter-section justify-content-center">
        <div class="col-md-4 mb-2" style="width:270px;">
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control rounded-pill border border-dark" placeholder="Filtrar por nome" />
        </div>
        <div class="col-md-4 mb-2" style="width:270px;">
            <select name="statusFilter" class="form-control rounded-pill border border-dark">
                <option value="">Todos os Status</option>
                @if (ViewBag.StatusFilter == "Em dia")
                {
                    <option value="Em dia" selected>Em dia</option>
                }
                else
                {
                    <option value="Em dia">Em dia</option>
                }

                @if (ViewBag.StatusFilter == "Atrasado")
                {
                    <option value="Atrasado" selected>Atrasado</option>
                }
                else
                {
                    <option value="Atrasado">Atrasado</option>
                }
            </select>
        </div>
        <div class="col-md-2 mb-2 d-flex" style="width:30%; gap:10px;">
            <button type="submit" class="btn filter-btn w-100 rounded-pill">Filtrar</button>
            <a href="@Url.Action("Index", "Mensalidades")" class="btn btn-outline-secondary rounded-pill w-100">Limpar</a>
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <p>Nenhum registro encontrado.</p>
    }
    else
    {
        <div>
            <table class="tabelaInfo">
                <thead>
                    <tr>
                        <th scope="col">Nome</th>
                        <th scope="col">Status</th>
                        <th scope="col">Último Pagamento</th>
                        <th scope="col">Próximo Pagamento</th>
                        <th scope="col">Saldo</th>
                        <th scope="col"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <th scope="col">@item.Nome</th>
                            <th scope="col">
                                @if (item.Status == "Em dia")
                                {
                                    <span class="badge text-dark fw-normal" style="background-color: #e0e0e0; border: 1px solid #ccc; padding: 6px 12px; border-radius: 12px;">Em dia</span>
                                }
                                else if (item.Status == "Atrasado")
                                {
                                    <span class="badge text-dark fw-normal" style="background-color: #d0d0d0; border: 1px solid #aaa; padding: 6px 12px; border-radius: 12px;">Atrasado</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border fw-normal" style="padding: 6px 12px; border-radius: 12px;">@item.Status</span>
                                }
                            </th>
                            <th scope="col">@(item.UltimoPagamento.HasValue ? item.UltimoPagamento.Value.ToString("dd/MM/yyyy") : "-")</th>
                            <th scope="col">@(item.ProximoPagamento.HasValue ? item.ProximoPagamento.Value.ToString("dd/MM/yyyy") : "-")</th>
                            <th scope="col">@(item.Saldo.ToString("C"))</th>
                            <td>
                                <div class="btn-group" role="group">
                                    <a role="button" class="btn btn-secondary m-2" style="border-radius: 20px;" asp-controller="Mensalidades" asp-action="Detalhes" asp-route-id="@item.AlunoId">Detalhes</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
